#!/usr/bin/env bash
#
# Pre-commit hook pentru Dosar.
#
# Activează prin: npm run setup-hooks   (rulează `git config core.hooksPath scripts/hooks`)
# Skip o singură dată: git commit --no-verify
#
# Rulează în ordinea:
#   1. TypeScript type-check
#   2. backup-audit (--strict)              — tabele SQLite ↔ backup/cloud
#   3. check-hardcoded-entities (--strict)   — anti-hardcode EntityType
#   4. knowledge-audit (--strict)            — appKnowledge.ts ↔ services/screens
#   5. hook-contract-audit (warn)            — {loading, error, refresh}
#   6. catch-pattern-audit (--strict)        — instanceof Error guard
#   7. alter-table-trycatch-audit (--strict) — ALTER TABLE în try
#   8. modal-input-audit (warn)              — Modal transparent cu input
#   9. expo-public-secrets-audit (warn)      — EXPO_PUBLIC_* cu nume de secret
#  10. pin-secure-store-audit (--strict)     — PIN în AsyncStorage
#  11. lint:ast (ast-grep)                   — SQL injection, AI privacy, theme, doc types
#  12. update-site                           — regenerează docs/ + README din types
#  13. Stage docs/README dacă au fost modificate de regenerare.
#
# La eșec, abort și raportează prima eroare.

set -e

cd "$(git rev-parse --show-toplevel)"

echo "▸ TypeScript type-check..."
npm run -s type-check

echo "▸ Backup audit (strict)..."
node scripts/backup-audit.js --strict

echo "▸ Hardcoded entities check (strict)..."
node scripts/check-hardcoded-entities.js --strict

echo "▸ Knowledge audit (strict)..."
node scripts/knowledge-audit.js --strict

echo "▸ Hook contract audit (warn — 7 violări preexistente)..."
node scripts/hook-contract-audit.js

echo "▸ Catch pattern audit (strict)..."
node scripts/catch-pattern-audit.js --strict

echo "▸ ALTER TABLE try-catch audit (strict)..."
node scripts/alter-table-trycatch-audit.js --strict

echo "▸ Modal-input audit (warn — 2 violări preexistente)..."
node scripts/modal-input-audit.js

echo "▸ EXPO_PUBLIC secrets audit (warn în hook — finding critic în .env)..."
node scripts/expo-public-secrets-audit.js

echo "▸ PIN SecureStore audit (strict)..."
node scripts/pin-secure-store-audit.js --strict

echo "▸ ast-grep scan (lint:ast)..."
npm run -s lint:ast

echo "▸ Site / docs / README regen..."
node scripts/update-site.js

# Dacă regenerarea a produs schimbări reale, stage-uiește-le ca să intre în
# același commit (consistență cod ↔ docs garantată).
CHANGED=$(git diff --name-only docs/ README.md 2>/dev/null || true)
if [ -n "$CHANGED" ]; then
  echo "  [stage] $(echo "$CHANGED" | wc -l | tr -d ' ') fișier(e) regenerat(e) → adăugate la commit"
  echo "$CHANGED" | xargs git add
fi

echo "✓ pre-commit OK"
